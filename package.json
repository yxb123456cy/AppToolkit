{
    "name": "apptoolkit-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "AppToolkit Monorepo for Desktop and TUI CLI",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
        "clean": "turbo run clean && rm -rf node_modules"
    },
    "devDependencies": {
        "prettier": "^3.8.4",
        "turbo": "^2.9.18",
        "typescript": "^6.0.3"
    },
    "packageManager": "pnpm@11.8.0"
}